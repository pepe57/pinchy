{
  "name": "@pinchy/web",
  "version": "0.5.7",
  "private": true,
  "scripts": {
    "dev": "node -r ./server-preload.cjs --import tsx server.ts",
    "build": "next build --turbopack",
    "start": "NODE_ENV=production node -r ./server-preload.cjs --import tsx server.ts",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:db": "vitest run --config vitest.integration.config.ts",
    "test:db:watch": "vitest --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:telegram": "playwright test --config playwright.telegram.config.ts",
    "test:e2e:odoo": "playwright test --config playwright.odoo.config.ts",
    "test:e2e:setup-wizard": "playwright test --config playwright.setup-wizard.config.ts",
    "test:e2e:web": "playwright test --config playwright.web.config.ts",
    "test:e2e:email": "playwright test --config playwright.email.config.ts",
    "test:integration": "playwright test --config playwright.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "reset-admin": "node --import tsx scripts/reset-admin.ts",
    "domain:reset": "node --import tsx scripts/domain-reset.ts",
    "generate-pwa-assets": "node --import tsx scripts/generate-pwa-assets.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.11",
    "@assistant-ui/react-markdown": "^0.14.1",
