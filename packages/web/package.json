    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^29.1.1",
    "openclaw": "2026.6.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
