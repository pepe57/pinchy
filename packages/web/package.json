    "ajv": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "browser-image-compression": "^2.0.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.1",
    "i18n-iso-countries": "^7.14.0",
    "iso-639-1": "^3.1.5",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "odoo-node": "0.2.0",
    "openclaw-node": "0.12.1",
    "pdfkit": "^0.18.0",
