    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.1",
    "react-simple-code-editor": "^0.14.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
