{
  "id": "pinchy-files",
  "name": "Pinchy Files",
  "description": "Scoped file access for Pinchy agents (KB + workspace).",
  "contracts": {
    "tools": ["pinchy_ls", "pinchy_read", "pinchy_write"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiBaseUrl": { "type": "string" },
      "gatewayToken": { "type": "string" },
      "visionModel": { "type": "string" },
      "agents": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed_paths": { "type": "array", "items": { "type": "string" } },
            "write_paths": { "type": "array", "items": { "type": "string" } },
            "allowed_extensions": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["allowed_paths"]
        }
      }
    },
    "required": ["agents"]
  }
}
